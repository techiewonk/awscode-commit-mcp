# AWS CodeCommit MCP — environment template
# Copy to .env and set as needed (or export in shell).

# Region (e.g. us-east-1)
AWS_REGION=us-east-1

# Option A: Named profile (uses ~/.aws/credentials and ~/.aws/config)
AWS_PROFILE=default

# Option B: Explicit keys (overrides profile)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional: custom paths (defaults: ~/.aws/credentials, ~/.aws/config)
# AWS_CREDENTIALS_FILE=
# AWS_CONFIG_FILE=
